<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/material_dynamic_primary80">

    <!-- TITLE -->
    <TextView
        android:id="@+id/settingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        android:text="Settings ⚙️"
        android:textColor="#546E7A"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- LOGOUT -->
    <Button
        android:id="@+id/logoutButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@android:color/white"
        android:text="Logout"
        android:textAllCaps="false"
        android:textColor="@color/purple_background"
        android:textSize="16sp"

        app:layout_constraintTop_toBottomOf="@id/settingsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ABOUT US CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/aboutCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"

        app:cardCornerRadius="8dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#26FFFFFF"
        app:strokeColor="#55FFFFFF"
        app:strokeWidth="1dp"

        app:layout_constraintTop_toBottomOf="@id/logoutButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About Jelly Jams 🎧"
                android:textColor="#616161"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- DESCRIPTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Jelly Jams is a mood/social based music reccomendations app that lets users share their music taste, track listening history, and connect with friends through music."
                android:textColor="#6D4C41"
                android:textSize="14sp" />

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#55FFFFFF"/>

            <!-- PURPOSE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Our Purpose:"
                android:textColor="#546E7A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=" Hi! We are the creators of Jelly Jams. The focus of our app is to create a creative way to share your music taste/history with your other friends. The development of our app showcases the ability to make user interface design, build practical programming skills, and possibly get more comfortable with using Android Studio. We are passionate about creating an app that can produce productivity as well as social interaction with your peers. We managed to create an environment that would both improve our coding skills as well as maintain a creative atmosphere. Jelly Jams serves as an early-stage project that can be built upon but still represents our broader goal of creating a creative application. "
                android:textColor="#6D4C41" />

            <!-- TEAM -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="Created by:"
                android:textColor="#546E7A"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="• Jaylen Santiago\n• Joanna Estrada\n• Brianna Moore"
                android:textColor="#6D4C41" />

            <!-- PURPOSE -->


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
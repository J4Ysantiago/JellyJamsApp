<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/material_dynamic_tertiary80">

    <TextView
        android:id="@+id/spinnerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spin For A Mood 🎡"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginTop="80dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/randomMoodResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap Spin!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/spinnerTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="40dp"/>

    <Button
        android:id="@+id/spinButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:layout_marginTop="84dp"
        android:backgroundTint="@android:color/white"
        android:text="Spin 🎲"
        android:textAllCaps="false"
        android:textColor="@color/material_dynamic_neutral_variant100"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/randomMoodResult" />

    <TextView
        android:id="@+id/spinRecommendations"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:layout_margin="24dp"
        android:lineSpacingExtra="6dp"
        app:layout_constraintTop_toBottomOf="@id/spinButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>